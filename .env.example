# Arbitrum Sepolia
ARB_SEPOLIA_RPC=https://sepolia-rollup.arbitrum.io/rpc
DEPLOYER_PK=0x...

# Deployed addresses (filled after `pnpm deploy:sepolia`)
NEXT_PUBLIC_PAYROLL_ADDR=
NEXT_PUBLIC_FACTORY_ADDR=
NEXT_PUBLIC_CUSDC_ADDR=
NEXT_PUBLIC_USDC_ADDR=

# Optional: custom RPC for the frontend (if blank, public fallbacks are used)
NEXT_PUBLIC_ARB_SEPOLIA_RPC=

# iExec Nox
NEXT_PUBLIC_NOX_ENV=sepolia

# ChainGPT (server-only, get credits via @vladnazarxyz on Telegram)
CHAINGPT_API_KEY=

# WalletConnect
NEXT_PUBLIC_WALLETCONNECT_ID=
